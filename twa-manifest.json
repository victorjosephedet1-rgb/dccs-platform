{
  "packageId": "com.victor360brand.dccs",
  "host": "dccsverify.com",
  "name": "DCCS - Digital Copyright Protection",
  "launcherName": "DCCS",
  "display": "standalone",
  "themeColor": "#FF5A1F",
  "navigationColor": "#0B0F17",
  "navigationColorDark": "#0B0F17",
  "navigationDividerColor": "#0B0F17",
  "navigationDividerColorDark": "#0B0F17",
  "backgroundColor": "#0B0F17",
  "enableNotifications": true,
  "startUrl": "/?source=twa",
  "iconUrl": "https://dccsverify.com/android-chrome-512x512.png",
  "maskableIconUrl": "https://dccsverify.com/android-chrome-512x512.png",
  "monochromeIconUrl": "https://dccsverify.com/android-chrome-512x512.png",
  "splashScreenFadeOutDuration": 300,
  "signingKey": {
    "path": "./android.keystore",
    "alias": "dccs-key"
  },
  "appVersionName": "1.0.0",
  "appVersionCode": 1,
  "shortcuts": [
    {
      "name": "Upload & Protect",
      "short_name": "Upload",
      "url": "/upload?source=twa-shortcut",
      "icon": "https://dccsverify.com/android-chrome-192x192.png"
    },
    {
      "name": "My Files",
      "short_name": "Files",
      "url": "/downloads?source=twa-shortcut",
      "icon": "https://dccsverify.com/android-chrome-192x192.png"
    },
    {
      "name": "Verify Code",
      "short_name": "Verify",
      "url": "/verify?source=twa-shortcut",
      "icon": "https://dccsverify.com/android-chrome-192x192.png"
    }
  ],
  "generatorApp": "bubblewrap-cli",
  "webManifestUrl": "https://dccsverify.com/manifest.json",
  "fallbackType": "customtabs",
  "features": {
    "locationDelegation": {
      "enabled": false
    },
    "playBilling": {
      "enabled": false
    }
  },
  "alphaDependencies": {
    "enabled": false
  },
  "isChromeOSOnly": false,
  "orientation": "default",
  "fullScreenMode": "sticky-immersive"
}
