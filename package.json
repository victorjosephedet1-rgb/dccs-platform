{
  "name": "@dccs/platform",
  "description": "Digital Creative Copyright System (DCCS) - Prove ownership of digital assets using Digital Clearance Code System technology. Platform by Victor360 Brand Limited.",
  "author": "Victor360 Brand Limited (Founded by Victor Joseph Edet)",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "keywords": [
    "DCCS",
    "Digital Creative Copyright System",
    "Digital Clearance Code System",
    "copyright protection",
    "digital ownership",
    "asset fingerprinting",
    "creator rights",
    "Victor360 Brand Limited"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/update-sitemap.js || true",
    "build": "node scripts/generate-version-file.js || true && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "health-check": "bash scripts/health-check.sh production",
    "smoke-test": "bash scripts/smoke-tests.sh https://dccsverify.com",
    "rollback": "bash scripts/rollback-deployment.sh",
    "update-sitemap": "node scripts/update-sitemap.js",
    "backup-schema": "bash scripts/backup-deployment-schema.sh"
  },
  "dependencies": {
    "@supabase/storage-js": "^2.12.1",
    "@supabase/supabase-js": "^2.55.0",
    "ethers": "^6.13.0",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.7.3",
    "react-router-dom": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.1.12",
    "vite-plugin-pwa": "^1.1.0"
  }
}
