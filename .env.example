# Digital Creative Copyright System (DCCS)
# Platform operated by Victor360 Brand Limited
#
# DCCS has two meanings:
# 1. Platform Name: Digital Creative Copyright System - Where creators register digital assets
# 2. Technology: Digital Clearance Code System - Proprietary ownership verification technology

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# SSO Configuration (Victor360 Brand)
# Shared secret for SSO token verification (must match victor360brand.com)
VITE_SSO_SECRET=your_shared_sso_secret_key

# Stripe API Keys
# Get from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Blockchain Configuration
# Default chain ID (84532 = Base Sepolia, 8453 = Base Mainnet)
VITE_DEFAULT_CHAIN_ID=84532

# RPC URLs (optional - defaults to public RPCs)
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_BASE_RPC_URL=https://mainnet.base.org

# DCCS Smart Contract Addresses (Phase 2+)
# Updated after blockchain deployment
VITE_ROYALTY_SPLITTER_ADDRESS=
VITE_DCCS_REGISTRY_ADDRESS=
VITE_LICENSE_NFT_ADDRESS=
VITE_INSTANT_PAYOUT_ADDRESS=

# Netlify Configuration (for automated deployments)
NETLIFY_SITE_ID=your_netlify_site_id_here
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token_here

# Platform Metadata
VITE_PLATFORM_NAME=DCCS - Digital Creative Copyright System
VITE_COMPANY_NAME=Victor360 Brand Limited

# Example:
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
