# Git Attributes for DCCS Platform
# Ensures proper attribution for Victor Joseph Edet

# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare files as text and normalize line endings to LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Denote all files that are truly binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.flac binary
*.pdf binary

